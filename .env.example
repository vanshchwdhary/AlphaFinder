# Copy to .env and fill values as needed.

# Database (default is local SQLite)
STOCK_SCOUT_DATABASE_URL=sqlite:///./stock_scout.db

# Data providers
STOCK_SCOUT_PRICE_PROVIDER=yfinance
STOCK_SCOUT_FUNDAMENTALS_PROVIDER=yfinance

# Universe (CSV with columns: symbol,exchange,name)
STOCK_SCOUT_UNIVERSE_PATH=./data/universe_sample.csv

# Alpha Vantage (optional)
STOCK_SCOUT_ALPHAVANTAGE_API_KEY=

# Zerodha Kite Connect (optional)
STOCK_SCOUT_KITE_API_KEY=
STOCK_SCOUT_KITE_ACCESS_TOKEN=

# Alerts (optional)
STOCK_SCOUT_TELEGRAM_BOT_TOKEN=
STOCK_SCOUT_TELEGRAM_CHAT_ID=
STOCK_SCOUT_DISCORD_WEBHOOK_URL=

